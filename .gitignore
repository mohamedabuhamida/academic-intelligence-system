# --- General / OS ---
.DS_Store
.AppleDouble
.LSOverride
*.pem
*.log
.env
.env.*
!.env.example

# --- Frontend (Next.js / Node) ---
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
frontend/next-env.d.ts
frontend/*.tsbuildinfo
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# --- Backend (Python / FastAPI) ---
__pycache__/
*.py[cod]
*$py.class
backend/__pycache__/
backend/*.py[cod]
backend/.venv/
backend/env/
backend/venv/
backend/ENV/
backend/.pytest_cache/
backend/.python-version
backend/.ipynb_checkpoints/

# --- ML Models & Data ---
# Ignore large model files, but allow the folder structure
backend/models/*.pkl
backend/models/*.h5
backend/models/*.onnx
backend/app/data/*.csv
backend/app/data/*.json

# --- Docker ---
.docker/
# Ignore local docker data if you mount volumes for DBs
**/postgres-data/

# --- Testing ---
coverage/
frontend/coverage/
backend/htmlcov/
backend/.tox/
backend/.coverage
backend/.coverage.*

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo

# Auto-committer ignored files
*.tmp
*.temp
*.cache
*.dll
*.exe
*.env
.vscode/**
.idea/**
.vs/**
node_modules/**
.git/**
dist/**
build/**
Thumbs.db
